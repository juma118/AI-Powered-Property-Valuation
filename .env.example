# ---------------------------------------------------------------------------
# Copy this file to .env (`cp .env.example .env`) before running `make up`.
# With USE_MOCK_DATA=true and empty API keys the entire stack runs end-to-end
# with ZERO external accounts — every external client returns deterministic
# mock data and the AI service returns canned-but-plausible responses.
# ---------------------------------------------------------------------------

# --- Database (async SQLAlchemy + asyncpg). `db` is the docker-compose host. ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/proptech

# --- Auth / JWT ---
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- External data providers (leave blank to use deterministic mock data) ---
RENTCAST_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- OpenAI (leave OPENAI_API_KEY blank to use the hash-based embedding /
#     canned-chat fallback; no network calls are made). ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Redis (Celery broker + result backend). `redis` is the compose host. ---
REDIS_URL=redis://redis:6379/0

# --- Master switch: when true, ALL external calls are short-circuited to mocks ---
USE_MOCK_DATA=true

# --- CORS: comma-separated list of allowed frontend origins ---
CORS_ORIGINS=http://localhost:3000
